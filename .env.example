# 預設供應商：gemini（免費、不需綁卡）或 claude（需綁卡儲值）
LLM_PROVIDER=gemini

# --- Gemini ---
# 申請（免費、不需綁信用卡）：https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 使用的模型（免費方案；flash-lite 每日免費額度較高，適合 demo）
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Claude（選用）---
# 兩家金鑰都填好後，管理員可在前端問答區即時切換 LLM。
# 申請（需綁卡儲值）：https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# 管理密碼：設了之後，上傳／刪除文件才需要這組密鑰（提問問答仍對所有人開放）。
# 線上版（Render）務必設定，否則任何人都能上傳/刪除。本機留空則不限制，方便開發。
ADMIN_TOKEN=
